# ── Provider LLM ──────────────────────────────────────────────
# Obslugiwane: groq, openai, openrouter (lub dowolny OpenAI-compatible)
LLM_PROVIDER=groq

# Klucz API do wybranego providera (wymagany dla trybu LLM)
LLM_API_KEY=

# Model do uzycia (domyslny zalezy od providera)
LLM_MODEL=qwen/qwen3-32b

# Endpoint API (domyslny ustawiany automatycznie dla groq/openrouter)
LLM_BASE_URL=https://api.groq.com/openai/v1

# ── Opcjonalne ────────────────────────────────────────────────
# Wlacz/wylacz agenta LLM (bez klucza dziala fallback regulowy)
ENABLE_LLM_AGENT=true

# Poziom logowania: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── OpenRouter (opcjonalne) ───────────────────────────────────
# LLM_SITE_URL=http://localhost:8000
# LLM_APP_NAME=Vehicle AI Agent

# ── OpenAI (alternatywny provider) ───────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ── Baza danych i obrazy (domyslne wartosci dzialaja out-of-the-box) ──
# DATABASE_URL=sqlite:///data/vehicles.db
# IMAGES_DIR=images
